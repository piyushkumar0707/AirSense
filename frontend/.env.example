# AirSense Frontend — Environment Variables
# Copy this file to .env and set values

# Base URL for the backend API. In development, Vite proxies /api → http://localhost:5000
# so you can leave this blank and just use the Vite proxy config.
# For production/staging, set the full URL:
# VITE_API_BASE_URL=http://your-backend-url/api
VITE_API_BASE_URL="<YOUR_BACKEND_URL_HERE>"
